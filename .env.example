APP_NAME=ProCharacters Cloud
DEBUG=false
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# WebRTC ICE — STUN is always included; set all three TURN vars for production relay
# WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
# WEBRTC_TURN_URLS=["turn:turn.example.com:3478","turns:turn.example.com:5349"]
# WEBRTC_TURN_USERNAME=your-turn-username
# WEBRTC_TURN_CREDENTIAL=your-turn-credential

# --- Switch all three providers to RunPod / remote HTTP (uncomment block) ---
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://your-runpod-llm-endpoint/v1
# LLM_API_KEY=your-runpod-api-key
# TTS_PROVIDER=http
# TTS_BASE_URL=https://your-runpod-tts-endpoint
# TTS_API_KEY=your-runpod-api-key
# VIDEO_PROVIDER=http
# VIDEO_BASE_URL=https://your-runpod-musetalk-endpoint
# VIDEO_API_KEY=your-runpod-api-key
# PROVIDER_GATE_ENABLED=true
# PROVIDER_GATE_ALLOW_DEGRADED=true

# LLM — set provider=openai_compatible when RunPod/vLLM is reachable
LLM_PROVIDER=mock
LLM_BASE_URL=https://your-runpod-endpoint/v1
LLM_API_KEY=
LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

# TTS — set provider=http when RunPod TTS endpoint is reachable
TTS_PROVIDER=mock
TTS_BASE_URL=https://your-runpod-tts-endpoint
TTS_API_KEY=
TTS_VOICE=default
TTS_SAMPLE_RATE=24000
TTS_CHUNK_MIN_CHARS=20
TTS_CHUNK_MAX_CHARS=120

# Video / MuseTalk — set provider=http when RunPod MuseTalk is reachable
VIDEO_PROVIDER=mock
VIDEO_BASE_URL=https://your-runpod-musetalk-endpoint
VIDEO_API_KEY=
VIDEO_AVATAR_ID=default
VIDEO_FPS=25
VIDEO_WIDTH=512
VIDEO_HEIGHT=512

# Demo mode realism (enhances mock providers to closer match real variable timing/chunking)
MOCK_REALISTIC=true

# Companion persistence (Phase 3 — survives server restarts)
COMPANION_PERSIST_ENABLED=true
COMPANION_PERSIST_PATH=data/companion_sessions.json
COMPANION_SESSION_TTL_HOURS=72